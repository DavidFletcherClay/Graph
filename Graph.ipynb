    "\n",
    "dropdown = widgets.Dropdown(\n",
    "    options=['Act', 'Bud', 'PY'],\n",
    "    value='Act',\n",
    "    description='Select:'\n",
    ")\n",
    "\n",
    "widgets.interact(plot_line, column=dropdown)"
